{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/vDevPreview/MicrosoftTeams.schema.json",
  "manifestVersion": "devPreview",
  "id": "a8b3c4d5-e6f7-48a9-b0c1-d2e3f4a5b6c7",
  "version": "1.0.1",
  "name": {
    "short": "ThreadClear",
    "full": "ThreadClear - Conversation Analysis"
  },
  "description": {
    "short": "Analyze email threads for clarity, risk, and health",
    "full": "ThreadClear analyzes your email conversations to surface unanswered questions, tension points, risk signals, and communication health metrics. Check drafts before sending and get actionable insights from your inbox."
  },
  "developer": {
    "name": "BHM-IT LLC",
    "websiteUrl": "https://threadclear.com",
    "privacyUrl": "https://threadclear.com/privacy",
    "termsOfUseUrl": "https://threadclear.com/terms"
  },
  "icons": {
    "outline": "https://app.threadclear.com/assets/icons/icon-32x32.png",
    "color": "https://app.threadclear.com/assets/icons/icon-96x96.png"
  },
  "accentColor": "#0ea5e9",
  "extensions": [
    {
      "requirements": {
        "scopes": ["mail"]
      },
      "runtimes": [
        {
          "requirements": {
            "capabilities": [
              { "name": "Mailbox", "minVersion": "1.3" }
            ]
          },
          "id": "ReadTaskPaneRuntime",
          "type": "general",
          "code": {
            "page": "https://app.threadclear.com/assets/addin/taskpane.html"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "ReadTaskPaneRuntimeShow",
              "type": "openPage",
              "pinnable": false,
              "view": "dashboard"
            }
          ]
        },
        {
          "requirements": {
            "capabilities": [
              { "name": "Mailbox", "minVersion": "1.3" }
            ]
          },
          "id": "ComposeTaskPaneRuntime",
          "type": "general",
          "code": {
            "page": "https://app.threadclear.com/assets/addin/taskpane-compose.html"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "ComposeTaskPaneRuntimeShow",
              "type": "openPage",
              "pinnable": false,
              "view": "dashboard"
            }
          ]
        }
      ],
      "ribbons": [
        {
          "contexts": ["mailRead"],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "msgReadGroup",
                  "label": "ThreadClear",
                  "icons": [
                    { "size": 16, "url": "https://app.threadclear.com/assets/icons/icon-16x16.png" },
                    { "size": 32, "url": "https://app.threadclear.com/assets/icons/icon-32x32.png" },
                    { "size": 80, "url": "https://app.threadclear.com/assets/icons/icon-80x80.png" }
                  ],
                  "controls": [
                    {
                      "id": "msgReadOpenPaneButton",
                      "type": "button",
                      "label": "Analyze Thread",
                      "icons": [
                        { "size": 16, "url": "https://app.threadclear.com/assets/icons/icon-16x16.png" },
                        { "size": 32, "url": "https://app.threadclear.com/assets/icons/icon-32x32.png" },
                        { "size": 80, "url": "https://app.threadclear.com/assets/icons/icon-80x80.png" }
                      ],
                      "supertip": {
                        "title": "Analyze Thread",
                        "description": "Analyze this email thread for unanswered questions, tension points, and communication health."
                      },
                      "actionId": "ReadTaskPaneRuntimeShow"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "contexts": ["mailCompose"],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "msgComposeGroup",
                  "label": "ThreadClear",
                  "icons": [
                    { "size": 16, "url": "https://app.threadclear.com/assets/icons/icon-16x16.png" },
                    { "size": 32, "url": "https://app.threadclear.com/assets/icons/icon-32x32.png" },
                    { "size": 80, "url": "https://app.threadclear.com/assets/icons/icon-80x80.png" }
                  ],
                  "controls": [
                    {
                      "id": "msgComposeOpenPaneButton",
                      "type": "button",
                      "label": "Check My Draft",
                      "icons": [
                        { "size": 16, "url": "https://app.threadclear.com/assets/icons/icon-16x16.png" },
                        { "size": 32, "url": "https://app.threadclear.com/assets/icons/icon-32x32.png" },
                        { "size": 80, "url": "https://app.threadclear.com/assets/icons/icon-80x80.png" }
                      ],
                      "supertip": {
                        "title": "Check My Draft",
                        "description": "Check your draft for tone, completeness, and risk before sending."
                      },
                      "actionId": "ComposeTaskPaneRuntimeShow"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "MailboxItem.Read.User",
          "type": "Delegated"
        }
      ]
    }
  }
}
