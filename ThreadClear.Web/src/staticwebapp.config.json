{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/assets/*",
            "/*.css",
            "/*.js",
            "/*.svg",
            "/*.ico"
        ]
    },
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": [
                "anonymous"
            ]
        }
    ],
    "responseOverrides": {},
    "globalHeaders": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
    },
    "mimeTypes": {
        ".html": "text/html"
    }
}